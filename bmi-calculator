<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calculadora de IMC</title>
<meta name="description" content="Calculadora de Índice de Massa Corporal (IMC) com resultado visual e explicação das faixas.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0e1116;
    --surface: #161a22;
    --surface-alt: #1d222c;
    --border: #2a303c;
    --text: #edf0f5;
    --text-muted: #8b93a3;
    --accent: #7dd3fc;
    --low: #60a5fa;
    --ok: #34d399;
    --high: #fbbf24;
    --very-high: #f87171;
    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background:
      radial-gradient(ellipse 55% 45% at 85% 0%, rgba(125, 211, 252, 0.08), transparent),
      var(--bg);
    color: var(--text);
    font-family: var(--font-body);
  }
  .card {
    width: 100%;
    max-width: 440px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 32px 28px;
    box-shadow: 0 24px 60px -20px rgba(0,0,0,0.6);
  }
  .card__eyebrow { font-size: 13px; color: var(--accent); font-family: var(--font-display); margin-bottom: 6px; }
  h1 { font-family: var(--font-display); font-size: 24px; margin: 0 0 4px; }
  .subtitle { color: var(--text-muted); font-size: 14px; margin-bottom: 28px; }

  .row { display: flex; gap: 12px; }
  .field { flex: 1; margin-bottom: 16px; }
  label { display: block; font-size: 12.5px; color: var(--text-muted); margin-bottom: 6px; }
  input {
    width: 100%;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 13px 14px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 15px;
  }
  input:focus { outline: none; border-color: var(--accent); }

  .btn {
    width: 100%;
    margin-top: 6px;
    padding: 14px;
    border-radius: 10px;
    border: none;
    background: var(--accent);
    color: #06263b;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: background 150ms ease;
  }
  .btn:hover { background: #a5e3ff; }

  .result { margin-top: 24px; display: none; }
  .result.is-visible { display: block; }

  .result__value {
    font-family: var(--font-display);
    font-size: 40px;
    text-align: center;
    margin-bottom: 4px;
  }
  .result__category {
    text-align: center;
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 18px;
  }

  .gauge {
    position: relative;
    height: 10px;
    border-radius: 6px;
    background: linear-gradient(to right, var(--low) 0 18.5%, var(--ok) 18.5% 55.5%, var(--high) 55.5% 70%, var(--very-high) 70% 100%);
    margin-bottom: 8px;
  }
  .gauge__marker {
    position: absolute;
    top: -5px;
    width: 3px;
    height: 20px;
    background: var(--text);
    border-radius: 2px;
    transform: translateX(-50%);
    transition: left 300ms ease;
  }
  .gauge__labels {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 22px;
  }

  .ranges { list-style: none; margin: 0; padding: 0; font-size: 13px; }
  .ranges li {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
  }
  .ranges li:first-child { border-top: none; }
  .ranges li.is-active { color: var(--text); font-weight: 600; }
  .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 8px; }

  .disclaimer { font-size: 12px; color: var(--text-muted); margin-top: 20px; line-height: 1.5; }
  .credit { text-align: center; font-size: 12px; color: var(--text-muted); margin-top: 18px; }
  .credit a { color: var(--text-muted); text-decoration: underline; }
  .credit a:hover { color: var(--accent); }
</style>
</head>
<body>

  <main class="card">
    <p class="card__eyebrow">&gt; imc</p>
    <h1>Calculadora de IMC</h1>
    <p class="subtitle">Índice de Massa Corporal — uma referência geral, não um diagnóstico.</p>

    <form id="bmiForm">
      <div class="row">
        <div class="field">
          <label for="weight">Peso (kg)</label>
          <input type="number" id="weight" min="1" step="0.1" placeholder="70" required>
        </div>
        <div class="field">
          <label for="height">Altura (cm)</label>
          <input type="number" id="height" min="1" step="0.1" placeholder="170" required>
        </div>
      </div>
      <button type="submit" class="btn">Calcular</button>
    </form>

    <div class="result" id="result">
      <div class="result__value" id="resultValue">—</div>
      <div class="result__category" id="resultCategory">—</div>

      <div class="gauge">
        <div class="gauge__marker" id="gaugeMarker" style="left: 0%"></div>
      </div>
      <div class="gauge__labels"><span>15</span><span>40</span></div>

      <ul class="ranges" id="rangesList">
        <li data-range="low"><span><span class="dot" style="background: var(--low)"></span>Abaixo do peso</span><span>&lt; 18,5</span></li>
        <li data-range="ok"><span><span class="dot" style="background: var(--ok)"></span>Peso normal</span><span>18,5 – 24,9</span></li>
        <li data-range="high"><span><span class="dot" style="background: var(--high)"></span>Sobrepeso</span><span>25 – 29,9</span></li>
        <li data-range="very-high"><span><span class="dot" style="background: var(--very-high)"></span>Obesidade</span><span>≥ 30</span></li>
      </ul>
    </div>

    <p class="disclaimer">
      O IMC é um indicador geral e não considera fatores como massa muscular, idade ou composição corporal.
      Para uma avaliação completa da sua saúde, consulte um profissional.
    </p>

    <p class="credit">
      feito por <a href="https://projeto-git-gold.vercel.app/" target="_blank" rel="noopener">Felipe Lima Machado</a>
    </p>
  </main>

<script>
(() => {
  'use strict';

  const form = document.getElementById('bmiForm');
  const resultEl = document.getElementById('result');
  const resultValueEl = document.getElementById('resultValue');
  const resultCategoryEl = document.getElementById('resultCategory');
  const gaugeMarker = document.getElementById('gaugeMarker');
  const rangesList = document.getElementById('rangesList');

  const CATEGORIES = [
    { key: 'low', max: 18.5, label: 'Abaixo do peso', color: 'var(--low)' },
    { key: 'ok', max: 25, label: 'Peso normal', color: 'var(--ok)' },
    { key: 'high', max: 30, label: 'Sobrepeso', color: 'var(--high)' },
    { key: 'very-high', max: Infinity, label: 'Obesidade', color: 'var(--very-high)' }
  ];

  const GAUGE_MIN = 15;
  const GAUGE_MAX = 40;

  form.addEventListener('submit', e => {
    e.preventDefault();

    const weight = parseFloat(document.getElementById('weight').value);
    const heightCm = parseFloat(document.getElementById('height').value);

    if (!weight || !heightCm || weight <= 0 || heightCm <= 0) return;

    const heightM = heightCm / 100;
    const bmi = weight / (heightM * heightM);
    const category = CATEGORIES.find(c => bmi < c.max);

    resultValueEl.textContent = bmi.toLocaleString('pt-BR', { maximumFractionDigits: 1 });
    resultValueEl.style.color = category.color;
    resultCategoryEl.textContent = category.label;
    resultCategoryEl.style.color = category.color;

    const clamped = Math.min(Math.max(bmi, GAUGE_MIN), GAUGE_MAX);
    const percent = ((clamped - GAUGE_MIN) / (GAUGE_MAX - GAUGE_MIN)) * 100;
    gaugeMarker.style.left = percent + '%';

    rangesList.querySelectorAll('li').forEach(li => {
      li.classList.toggle('is-active', li.dataset.range === category.key);
    });

    resultEl.classList.add('is-visible');
  });
})();
</script>
</body>
</html>
